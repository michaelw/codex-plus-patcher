{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommits"
  ],
  "enabledManagers": [
    "npm",
    "github-actions"
  ],
  "packageRules": [
    {
      "description": "Automerge Renovate npm and GitHub Actions minor/patch updates after required CI passes",
      "matchManagers": [
        "npm",
        "github-actions"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "automergeStrategy": "rebase",
      "platformAutomerge": true
    }
  ]
}
